node_modules/
file-box-web/dist/
file-box-web/dist-ssr/
*.tsbuildinfo
.eslintcache
.stylelintcache
.parcel-cache/
.next/
.npm/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage
coverage/

# Vite / Env
.env
.env.local
.env.*.local
.env.production
*.timestamp-*-*.mjs
*.timestamp-*-*.pjs

